{
  "expo": {
    "name": "SnackShot",
    "slug": "snackshot",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "snackshot",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.glyph8.snackshot",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "./plugins/withWidget",
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "SnackShot이 동영상 다이어리 녹화를 위해 카메라 접근을 요청합니다.",
          "microphonePermission": "SnackShot이 음성 일기를 위해 마이크 접근을 요청합니다.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "원본 영상을 저장할 폴더 접근을 요청합니다.",
          "savePhotosPermission": "녹화한 영상을 갤러리에 저장합니다.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
