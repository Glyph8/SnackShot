<?xml version="1.0" encoding="utf-8"?>
<!--
  의사결정 리스트 위젯 — 자유 리사이즈(가로/세로).
  기본 5×4, 3×3 ~ 5×5 등으로 조절 가능(4×3·4×4·4×5·5×4 모두 포함).
    minResize 180×110dp (≈3×2), maxResize 440×520dp (≈5×6 한도)
  updatePeriodMillis 1800000(30분): 주기 새로고침(헤더 새로고침 버튼으로 즉시 갱신).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:targetCellWidth="5"
    android:targetCellHeight="4"
    android:minResizeWidth="180dp"
    android:minResizeHeight="110dp"
    android:maxResizeWidth="440dp"
    android:maxResizeHeight="520dp"
    android:updatePeriodMillis="1800000"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:initialLayout="@layout/snackshot_decisions_widget" />
