<?xml version="1.0" encoding="utf-8"?>
<!--
  가로형 캡처 바 위젯 — 4×2 셀 (~250dp × 110dp)
  minWidth/minHeight : API < 31 호환 (74dp × n - 2 공식)
  targetCellWidth/Height : API 31+ (Android 12)
  updatePeriodMillis=0 : 시스템 주기 업데이트 불필요 (onUpdate는 설치/리프레시 시)
  resizeMode=horizontal : 가로 리사이즈 허용
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:resizeMode="horizontal"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:initialLayout="@layout/snackshot_widget" />
