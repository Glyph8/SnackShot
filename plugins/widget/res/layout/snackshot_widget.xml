<?xml version="1.0" encoding="utf-8"?>
<!--
  SnackShot 홈 위젯 — 아이콘 캡처 바 (텍스트 없이 아이콘만)
  RemoteViews 지원 뷰만 사용 (FrameLayout, LinearLayout, ImageView)
  작은 크기에서도 글자가 넘치지 않도록 라벨 제거.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 종이 카드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/widget_background"
        android:padding="10dp">

        <!-- 영상 (primary) -->
        <LinearLayout
            android:id="@+id/widget_btn_video"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:background="@drawable/widget_btn_primary"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_widget_video"
                android:tint="@color/widget_on_primary"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- 음성 (secondary) -->
        <LinearLayout
            android:id="@+id/widget_btn_audio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:background="@drawable/widget_btn_secondary"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_widget_mic"
                android:tint="@color/widget_text"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- 직접 쓰기 (secondary) -->
        <LinearLayout
            android:id="@+id/widget_btn_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/widget_btn_secondary"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_widget_pencil"
                android:tint="@color/widget_text"
                android:importantForAccessibility="no" />
        </LinearLayout>
    </LinearLayout>

    <!-- 마스킹 테이프 장식 -->
    <ImageView
        android:layout_width="50dp"
        android:layout_height="16dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="18dp"
        android:background="@drawable/widget_tape"
        android:importantForAccessibility="no" />

</FrameLayout>
